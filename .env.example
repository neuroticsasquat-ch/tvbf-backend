DATABASE_URL=postgresql+asyncpg://root:root@tbc_postgresql_db:5432/tvbf
TEST_DATABASE_URL=postgresql+asyncpg://root:root@tbc_postgresql_db:5432/tvbf_test
ADMIN_TOKEN=dev-secret-change-me

# scripts/refresh_db.sh — pull prod data into local tvbf via SSH + docker exec.
# Required:
#   PROD_SSH=user@host    SSH target where prod Postgres runs in a container.
# Optional overrides:
#   PROD_PG_USER          Defaults to the container's POSTGRES_USER env. Set
#                         this if your real user differs from POSTGRES_USER.
#   PROD_PG_DB            Defaults to the container's POSTGRES_DB env. Set this
#                         if the real database was created on top of the
#                         container's default DB (common with Coolify, where
#                         POSTGRES_DB=postgres and the app's DB is `tvbf`).
#   LOCAL_PG_CONTAINER=tbc_postgresql_db
#   LOCAL_DB=tvbf
#   LOCAL_DB_USER=root
#   ANONYMIZE=1           Set to 0 only for `both` mode when you need real prod app data.
#   ADMIN_EMAIL           If set, that user's email is preserved during anonymization
#                         so you can log in locally as your real prod identity. The
#                         password is still set to 'localdev'.
PROD_SSH=
PROD_PG_DB=tvbf
ADMIN_EMAIL=
